---
const { title } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Be+Vietnam+Pro:wght@300;400;500&subset=vietnamese&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">curiousmeye</a>
    <div class="nav-links">
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
  </nav>

  <slot />

</body>
</html>
